# Template for release signing.
#
# 1. Copy this file to "keystore.properties" in the project root (same folder).
# 2. Fill in your real values.
# 3. Never commit keystore.properties — it's gitignored on purpose.
#
# The release build is signed only when keystore.properties exists; otherwise the release APK is
# built unsigned (e.g. for an F-Droid/IzzyOnDroid server that signs it on their side).

# Path to your keystore — absolute, or relative to the project root.
storeFile=/absolute/path/to/your/release.jks
# Password of the keystore (the store).
storePassword=CHANGE_ME
# Alias of the key inside the keystore.
keyAlias=CHANGE_ME
# Password of that key.
keyPassword=CHANGE_ME
