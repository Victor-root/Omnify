    <string name="google_services_soft_title">Uses Google services</string>
    <string name="google_services_soft_summary">On a device without Google Play services, some features may be limited. microG usually restores them.</string>
    <string name="google_services_hard_title">Depends on Google services</string>
    <string name="google_services_hard_summary">This app depends on Google components that neither a de-Googled device nor microG provide. Some features may not work at all.</string>
    <string name="google_services_microg_full">Works with microG</string>
    <string name="google_services_microg_partial">Partial with microG</string>
